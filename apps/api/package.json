{
  "name": "@portalgis/api",
  "version": "0.1.0",
  "author": "laugis",
  "description": "API Fastify para PORTALGIS IDECAM.",
  "private": true,
  "main": "dist/src/index.js",
  "scripts": {
    "build": "node scripts/prisma-with-root-env.mjs generate && tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "typecheck": "node scripts/prisma-with-root-env.mjs generate && tsc -p tsconfig.json --noEmit",
    "lint": "node scripts/prisma-with-root-env.mjs generate && tsc -p tsconfig.json --noEmit",
    "db:generate": "node scripts/prisma-with-root-env.mjs generate",
    "db:migrate": "node scripts/prisma-with-root-env.mjs migrate deploy",
    "db:migrate:dev": "node scripts/prisma-with-root-env.mjs migrate dev --name init",
    "db:push": "node scripts/prisma-with-root-env.mjs db push",
    "db:seed": "tsx prisma/seed.ts",
    "data:sync": "tsx scripts/sync-wfs.ts",
    "data:sync:critical": "tsx scripts/sync-wfs.ts --critical"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@portalgis/gis-core": "workspace:*",
    "@portalgis/shared": "workspace:*",
    "@prisma/client": "^5.20.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.4",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
